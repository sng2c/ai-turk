#!/usr/bin/env bash
# turkctl — AI Turk 제어 스크립트
# 다중 인스턴스: TURK_ENV_FILE 환경변수 또는 --env <파일> 로 .env 파일 지정
set -euo pipefail

TURK_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
cd "$TURK_DIR"

# ── 인자 파싱 ────────────────────────────────────────────────────────────
# 사용법: turkctl [--env <파일> | -e <파일>] <명령>
ENV_FILE=""
ENV_FLAG=""
CMD=""
while [ $# -gt 0 ]; do
  case "$1" in
    --env|-e)
      shift
      ENV_FLAG="$1"
      shift
      ;;
    *)
      CMD="$1"
      shift
      ;;
  esac
done

# ENV_FILE 결정: --env 플래그 > TURK_ENV_FILE 환경변수 > 기본 .env
if [ -n "$ENV_FLAG" ]; then
  ENV_FILE="$ENV_FLAG"
elif [ -n "${TURK_ENV_FILE:-}" ]; then
  ENV_FILE="$TURK_ENV_FILE"
else
  ENV_FILE="$TURK_DIR/.env"
fi

# 절대경로 변환
case "$ENV_FILE" in
  /*) ;;
  *)  ENV_FILE="$TURK_DIR/$ENV_FILE" ;;
esac

# 자식 프로세스(vite/server.ts)도 동일 .env 를 읽도록 전파
export TURK_ENV_FILE="$ENV_FILE"

# .env 파일에서 TURK_PORT / TURK_HOST 읽기
# 우선순위: 환경변수 TURK_PORT > TURK_ENV_FILE 파일 > 기본값 3000
if [ -z "${TURK_PORT:-}" ] && [ -f "$ENV_FILE" ]; then
  TURK_PORT="$(grep -E '^TURK_PORT=' "$ENV_FILE" | tail -1 | cut -d'=' -f2- | tr -d '[:space:]' || true)"
fi
TURK_PORT="${TURK_PORT:-3000}"

if [ -z "${TURK_HOST:-}" ] && [ -f "$ENV_FILE" ]; then
  TURK_HOST="$(grep -E '^TURK_HOST=' "$ENV_FILE" | tail -1 | cut -d'=' -f2- | tr -d '[:space:]' || true)"
fi
TURK_HOST="${TURK_HOST:-127.0.0.1}"

LOG_FILE="/tmp/ai-turk-${TURK_PORT}.log"
PID_FILE="/tmp/ai-turk-${TURK_PORT}.pid"

# 자식 프로세스(vite/server.ts) 에 전달 — 환경변수로 명시
export TURK_PORT="$TURK_PORT"
export TURK_HOST="$TURK_HOST"

# .env 파일 내용을 환경변수로 로드 (Vite에 전달되도록)
load_env() {
  if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a
  fi
}

usage() {
  cat <<EOF
AI Turk 제어 도구

사용법: turkctl [--env <파일>] <명령>

옵션:
  --env <파일>  설정 파일 지정 (기본: .env)
                환경변수 TURK_ENV_FILE 로도 지정 가능 (--env 가 우선)
                예: TURK_ENV_FILE=.env.8003 turkctl start
                    turkctl --env .env.8003 start

명령:
  start     개발 서버 시작 (npm run dev, 백그라운드)
  stop      서버 및 pi 프로세스 종료 (해당 포트만)
  restart   서버 재시작
  status    실행 상태 확인
  logs      최근 로그 출력 (tail -f)
  build     프로덕션 빌드
  pi        pi RPC 프로세스 상태
  ws        WebSocket 연결 테스트
  session   현재 세션 정보 (HTTP)
  help      이 도움말

예시:
  turkctl start                         # .env 사용 (기본)
  TURK_ENV_FILE=.env.8003 turkctl start  # 환경변수로 .env.8003 지정
  turkctl --env .env.8003 start          # 플래그로 .env.8003 지정
  turkctl --env .env.8004 restart        # 8004 인스턴스 재시작
  turkctl status
  turkctl logs
EOF
}

is_running() {
  curl -s -o /dev/null -w "%{http_code}" "http://$TURK_HOST:$TURK_PORT/" 2>/dev/null | grep -q 200
}

# 특정 포트에 묶인 프로세스 종료 (다른 인스턴스 영향 안 줌)
# PID 파일 우선(표준 관리) — 없거나 살아있으면 lsof 폴백(기존 인스턴스 호환)
kill_port() {
  if [ -f "$PID_FILE" ]; then
    local pid
    pid=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill -9 -"$pid" 2>/dev/null || true      # 프로세스 그룹 전체 (자식/손자 포함)
      pkill -9 -P "$pid" 2>/dev/null || true   # 보조: 직접 자식
      kill -9 "$pid" 2>/dev/null || true
    fi
    rm -f "$PID_FILE"
  fi
  local pids
  pids=$(lsof -t -i :"$TURK_PORT" 2>/dev/null || true)
  if [ -n "$pids" ]; then
    for pid in $pids; do
      pkill -9 -P "$pid" 2>/dev/null || true
      kill -9 "$pid" 2>/dev/null || true
    done
  fi
}

cmd_start() {
  if is_running; then
    echo "✅ 이미 실행 중: http://$TURK_HOST:$TURK_PORT (env: $ENV_FILE)"
    return 0
  fi
  echo "▶ 서버 시작 중... (포트 $TURK_PORT, env: $ENV_FILE)"
  cd "$TURK_DIR"
  kill_port
  sleep 1
  load_env
  nohup node "$TURK_DIR/node_modules/vite/bin/vite.js" > "$LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"
  sleep 5
  if is_running; then
    echo "✅ 서버 실행됨: http://$TURK_HOST:$TURK_PORT"
    echo "   WebSocket: ws://$TURK_HOST:$TURK_PORT/ws"
    echo "   로그: $LOG_FILE"
  else
    echo "❌ 시작 실패 — 로그 확인: turkctl logs"
    tail -5 "$LOG_FILE" 2>/dev/null
    return 1
  fi
}

cmd_stop() {
  echo "▶ 중지 중... (포트 $TURK_PORT)"
  kill_port
  echo "✅ 서버 및 관련 프로세스 중지됨 (포트 $TURK_PORT)"
}

cmd_restart() {
  cmd_stop
  sleep 2
  cmd_start
}

cmd_status() {
  if is_running; then
    echo "✅ 서버 실행 중 (포트 $TURK_PORT, env: $ENV_FILE)"
    local health
    health=$(curl -s "http://$TURK_HOST:$TURK_PORT/api/health" 2>/dev/null || echo "{}")
    echo "   $health"
    local ws_count
    ws_count=$(grep -c "클라이언트 연결" "$LOG_FILE" 2>/dev/null || echo "0")
    echo "   로그: $LOG_FILE"
  else
    echo "⚪ 서버 미실행 (포트 $TURK_PORT) — turkctl --env $(basename "$ENV_FILE") start"
  fi
  local procs
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null; then
    procs=1
  else
    procs=$(lsof -t -i :"$TURK_PORT" 2>/dev/null | wc -l)
  fi
  echo "   관련 프로세스: ${procs}개"
}

cmd_logs() {
  if [ -f "$LOG_FILE" ]; then
    tail -f "$LOG_FILE"
  else
    echo "❌ 로그 파일 없음: $LOG_FILE"
  fi
}

cmd_build() {
  cd "$TURK_DIR"
  echo "▶ 빌드 중..."
  npm run build
  echo "✅ 빌드 완료: $TURK_DIR/dist/"
}

cmd_pi() {
  if is_running; then
    echo "=== pi 프로세스 ==="
    ps aux | grep "pi --mode rpc" | grep -v grep || echo "  pi 프로세스 없음"
    echo "=== 헬스체크 ==="
    curl -s "http://$TURK_HOST:$TURK_PORT/api/health" 2>/dev/null || echo "  응답 없음"
    echo
  else
    echo "⚪ 서버 미실행 (포트 $TURK_PORT)"
  fi
}

cmd_ws() {
  if ! is_running; then
    echo "⚪ 서버 미실행 (포트 $TURK_PORT)"
    return 1
  fi
  echo "=== WebSocket 테스트 (포트 $TURK_PORT) ==="
  cd "$TURK_DIR"
  npx tsx -e '
import WebSocket from "ws";
const ws = new WebSocket("ws://$TURK_HOST:'"$TURK_PORT"'/ws");
ws.on("open", () => { console.log("✅ WS 연결됨"); ws.send(JSON.stringify({ type: "get_state" })); });
ws.on("message", (raw) => {
  const msg = JSON.parse(raw.toString());
  if (msg.type === "pi_ready") console.log("✅ pi 준비됨");
  if (msg.type === "response" && msg.command === "get_state") {
    console.log("세션:", msg.data?.sessionId ?? "—");
    console.log("메시지 수:", msg.data?.messageCount ?? 0);
    ws.close(); process.exit(0);
  }
});
ws.on("error", (e) => { console.error("❌ WS 오류:", e.message); process.exit(1); });
setTimeout(() => { console.log("타임아웃"); process.exit(1); }, 10000);
' 2>&1
}

cmd_session() {
  if ! is_running; then
    echo "⚪ 서버 미실행 (포트 $TURK_PORT)"
    return 1
  fi
  cd "$TURK_DIR"
  npx tsx -e '
import WebSocket from "ws";
const ws = new WebSocket("ws://$TURK_HOST:'"$TURK_PORT"'/ws");
ws.on("open", () => ws.send(JSON.stringify({ type: "get_state" })));
ws.on("message", (raw) => {
  const msg = JSON.parse(raw.toString());
  if (msg.type === "response" && msg.command === "get_state" && msg.success) {
    const d = msg.data;
    console.log("세션 ID:", d.sessionId ?? "—");
    console.log("세션명:", d.sessionName ?? "—");
    console.log("모델:", d.model?.name ?? d.model?.id ?? "—");
    console.log("메시지 수:", d.messageCount ?? 0);
    console.log("사고 레벨:", d.thinkingLevel ?? "—");
    console.log("스트리밍:", d.isStreaming ? "예" : "아니오");
    ws.close(); process.exit(0);
  }
});
setTimeout(() => { console.log("타임아웃"); process.exit(1); }, 10000);
' 2>&1
}

# ── 메인 ────────────────────────────────────────────────────────────────
case "${CMD:-help}" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    cmd_logs ;;
  build)   cmd_build ;;
  pi)      cmd_pi ;;
  ws)      cmd_ws ;;
  session) cmd_session ;;
  help|--help|-h) usage ;;
  "") usage ;;
  *) echo "알 수 없는 명령: $CMD"; usage; exit 1 ;;
esac