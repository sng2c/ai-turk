# ───────────────────────────────────────────────────────────────────────
# AI Turk 환경 설정
# ───────────────────────────────────────────────────────────────────────
# 백엔드를 선택하고 필요한 변수만 채우면 됩니다.
# 백엔드별 변수는 분리되어 있으므로 사용하지 않는 쪽은 비워도 됩니다.

# ── 공통 ───────────────────────────────────────────────────────────────
# 서버 포트 (기본 3000)
TURK_PORT=3000
# 바인딩 호스트 (기본 127.0.0.1, 외부 노출 시 0.0.0.0)
TURK_HOST=127.0.0.1

# 백엔드 선택:  pi (기본)  |  claude
#   pi     — pi --mode rpc (로컬 pi CLI)
#   claude — claude -p stream-json (Anthropic Messages API 호환 엔드포인트)
TURK_BACKEND=pi

# 에이전트 실행 위치 (기본 ./workspace)
# TURK_AGENT_CWD=/root/ai-turk/workspace


# ── pi 백엔드 (TURK_BACKEND=pi) ────────────────────────────────────────
# TURK_PI_BIN=pi                              # pi CLI 바이너리 (기본 pi)
# TURK_PI_MODEL=ollama-cloud/gemini-3-flash-preview   # 미지정 시 pi 기본 모델
# TURK_PI_ARGS=                                # 추가 인자 (예: --no-tools)


# ── Claude Code 백엔드 (TURK_BACKEND=claude) ───────────────────────────
# ANTHROPIC_BASE_URL 이 가리키는 엔드포인트로 Anthropic Messages API 요청을 보냅니다.
# 아래 ①·② 중 하나만 설정하세요.
# TURK_CLAUDE_BIN=claude                      # Claude Code CLI 바이너리 (기본 claude)

# ① 순수 Anthropic Claude (권장)
#    ANTHROPIC_BASE_URL 을 비우면 기본 api.anthropic.com 사용.
# TURK_CLAUDE_MODEL=claude-haiku-4-5           # claude-* 전체 이름 (예: claude-haiku-4-5)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ② Ollama Claude (Ollama 0.14+ 의 Anthropic 호환 엔드포인트, ollama launch claude 동등)
#    Ollama 에 pull 된 모델만 사용 가능.
#    예: glm-5.1:cloud / glm-5.2:cloud / kimi-k2.7-code:cloud / glm-4.7:cloud
# TURK_CLAUDE_MODEL=glm-5.1:cloud
# ANTHROPIC_BASE_URL=http://localhost:11434
# ANTHROPIC_AUTH_TOKEN=ollama                 # 임의값 필수 (비어두면 subscription 폴백)


# ── 전환 치트시트 ──────────────────────────────────────────────────────
# 순수 Anthropic Claude:
#   TURK_BACKEND=claude
#   TURK_CLAUDE_MODEL=claude-haiku-4-5
#
# Ollama Claude:
#   TURK_BACKEND=claude
#   TURK_CLAUDE_MODEL=glm-5.1:cloud
#   ANTHROPIC_BASE_URL=http://localhost:11434
#   ANTHROPIC_AUTH_TOKEN=ollama


# ── 다중 인스턴스 ──────────────────────────────────────────────────────
# turkctl 의 --env 옵션 또는 TURK_ENV_FILE 환경변수로 인스턴스별 .env 파일 지정.
# 포트 충돌을 피하려면 각 .env 파일의 TURK_PORT 를 다르게 설정.
#
# 예: .env.8003 생성 후 (또는 TURK_ENV_FILE 환경변수로 지정)
#   turkctl --env .env.8003 start
#   turkctl --env .env.8003 status
#   turkctl --env .env.8003 stop
#
# .env.example 을 복사해 새 인스턴스용 .env 파일을 만들면 됩니다:
#   cp .env.example .env.8003  &&  TURK_PORT=8003 으로 수정