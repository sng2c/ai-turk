# ── AI Turk 백엔드 설정 ─────────────────────────────────────────────────
# 서버 포트 (단일 서버: 개발/프로덕션 모두 3000)
PORT=3000

# pi RPC 설정
TURK_RPC_BIN=pi
TURK_RPC_MODEL=ollama-cloud/gemini-3-flash-preview
# 추가 인자 (예: --no-tools 로 도구 비활성화)
TURK_RPC_ARGS=

# ── 레거시: API 직접 호출 모드 (fallback) ─────────────────────────────
OLLAMA_API_KEY=your-api-key-here
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=gemini-3-flash-preview

# 사용 모드: rpc | api
TURK_MODE=rpc

# CLI 에이전트 명령어 템플릿 (레거시)
TURK_CLI_CMD=pi --session-id {session} --model {model} --no-tools -p {prompt}
TURK_CLI_MODEL=ollama-cloud/gemini-3-flash-preview