# ── AI Turk 백엔드 설정 ─────────────────────────────────────────────────
# 서버 포트 (단일 서버: 개발/프로덕션 모두 3000)
PORT=3000

# 백엔드 선택: pi (기본) | claude
#   pi     — pi --mode rpc (로컬 pi CLI)
#   claude — claude -p stream-json (Anthropic API 또는 Ollama 호환 엔드포인트)
TURK_BACKEND=pi

# 에이전트 실행 위치 — 기본 ./workspace
# TURK_AGENT_CWD=/root/ai-turk/workspace

# ── claude 백엔드 (TURK_BACKEND=claude) ─────────────────────────────────
# Claude Code CLI 를 백엔드로 사용. ANTHROPIC_BASE_URL 로 가리키는 엔드포인트에
# Anthropic Messages API 요청을 보낸다. 두 가지 구성 가능:
#
# ① 순수 Anthropic Claude (권장, 가장 우선 설정)
#   - ANTHROPIC_BASE_URL 을 비우면 기본 api.anthropic.com 사용
#   - ANTHROPIC_API_KEY 또는 ANTHROPIC_AUTH_TOKEN 에 Anthropic 키 설정
#   - 모델: claude-* 별칭(opus/sonnet/haiku) 또는 전체 이름
#
# Claude Code CLI 바이너리 (기본 claude)
# TURK_CLAUDE_BIN=claude
# 사용 모델 (예: sonnet, opus, claude-sonnet-4-5, claude-opus-4-8)
# TURK_CLAUDE_MODEL=sonnet
# Anthropic API 키 — ANTHROPIC_API_KEY(x-api-key) 또는 ANTHROPIC_AUTH_TOKEN(Bearer)
# ANTHROPIC_API_KEY=sk-ant-...
# (또는) ANTHROPIC_AUTH_TOKEN=sk-ant-...
# 기본 엔드포인트(api.anthropic.com) 사용 시 아래 둘은 주석 처리:
# ANTHROPIC_BASE_URL=https://api.anthropic.com
#
# ── Ollama Claude (ANTHROPIC_BASE_URL 로 Ollama 지정) ──────────────────
# ② Ollama 0.14+ 가 /v1/messages (Anthropic Messages API) 를 네이티브 지원.
#    `ollama launch claude --model <m>` 와 동일한 환경을 코드로 재현.
#    Ollama 에 pull 된 모델만 사용 가능.
#
# 사용 모델 — Ollama 에 pull 된 모델. 예:
#   glm-5.1:cloud / glm-5.2:cloud / kimi-k2.7-code:cloud / glm-4.7:cloud
# TURK_CLAUDE_MODEL=glm-5.1:cloud
# Ollama Anthropic 호환 엔드포인트 (로컬 Ollama)
# ANTHROPIC_BASE_URL=http://localhost:11434
# 인증 토큰 — Ollama 는 무시하지만 Claude Code 가 비어있으면
# subscription 으로 폴백하므로 임의값 필수 (보통 "ollama")
# ANTHROPIC_AUTH_TOKEN=ollama
#
# ── 전환 예시 (주석 해제만 하면 전환) ───────────────────────────────────
# 순수 Anthropic Claude:
#   TURK_BACKEND=claude
#   TURK_CLAUDE_MODEL=sonnet
#   ANTHROPIC_API_KEY=sk-ant-...
#
# Ollama Claude:
#   TURK_BACKEND=claude
#   TURK_CLAUDE_MODEL=glm-5.1:cloud
#   ANTHROPIC_BASE_URL=http://localhost:11434
#   ANTHROPIC_AUTH_TOKEN=ollama

# ── pi 백엔드 (TURK_BACKEND=pi) ─────────────────────────────────────────
# Claude 백엔드 변수와 분리. (구명 TURK_RPC_* 도 하위호환으로 계속 인식)
# pi CLI 바이너리 (기본 pi)
# TURK_PI_BIN=pi
# 모델 미지정 시 pi 기본 모델 사용
# TURK_PI_MODEL=ollama-cloud/gemini-3-flash-preview
# 추가 인자 (예: --no-tools 로 도구 비활성화)
# TURK_PI_ARGS=

# ── 다중 인스턴스 ───────────────────────────────────────────────────────
# 인스턴스별 .env 파일 분리:
#   dev: PORT에 따라 .env.<PORT> 자동 로드 (예: PORT=3001 → .env.3001)
#   prod: TURK_ENV_FILE로 .env 경로 지정 (기본 .env)
# 예: TURK_ENV_FILE=.env.3001