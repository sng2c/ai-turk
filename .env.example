# ── AI Turk 백엔드 설정 ─────────────────────────────────────────────────
# 서버 포트 (단일 서버: 개발/프로덕션 모두 3000)
PORT=3000

# pi RPC 설정
TURK_RPC_BIN=pi
# 모델 미지정 시 pi 기본 모델 사용
# TURK_RPC_MODEL=ollama-cloud/gemini-3-flash-preview
# 추가 인자 (예: --no-tools 로 도구 비활성화)
TURK_RPC_ARGS=
# 에이전트(pi) 실행 위치 — 기본 ./workspace
# TURK_AGENT_CWD=/root/ai-turk/workspace

# ── 다중 인스턴스 ───────────────────────────────────────────────────────
# 인스턴스별 .env 파일 분리:
#   dev: PORT에 따라 .env.<PORT> 자동 로드 (예: PORT=3001 → .env.3001)
#   prod: TURK_ENV_FILE로 .env 경로 지정 (기본 .env)
# 예: TURK_ENV_FILE=.env.3001
