# ── API 직접 호출 모드 ──────────────────────────────────────────────────
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=gemini-3-flash-preview

# ── CLI 에이전트 모드 ───────────────────────────────────────────────────
# 사용 모드: api | cli
TURK_MODE=api

# CLI 에이전트 명령어 템플릿
# {session} → 세션 ID, {model} → 모델명, {prompt} → 질의
# pi:       pi --session-id {session} --model {model} --no-tools -p {prompt}
# ollama:   ollama run {model}
# aichat:   aichat --session {session} -m {model}
TURK_CLI_CMD=pi --session-id {session} --model {model} --no-tools -p {prompt}

# CLI 기본 모델
TURK_CLI_MODEL=ollama-cloud/gemini-3-flash-preview